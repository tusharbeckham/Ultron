# Resilience policy
ULTRON_TIMEOUT_MS=60000
ULTRON_MAX_RETRIES=2
ULTRON_RETRY_BASE_MS=500
ULTRON_RETRY_MAX_MS=10000

# Optional price inputs for estimates (USD per 1M tokens)
OPENAI_INPUT_USD_PER_MILLION=
OPENAI_OUTPUT_USD_PER_MILLION=
ANTHROPIC_INPUT_USD_PER_MILLION=
ANTHROPIC_OUTPUT_USD_PER_MILLION=
KIMI_INPUT_USD_PER_MILLION=
KIMI_OUTPUT_USD_PER_MILLION=
ULTRON_CUSTOM_INPUT_USD_PER_MILLION=
ULTRON_CUSTOM_OUTPUT_USD_PER_MILLION=
