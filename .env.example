# Credentials (export only what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
ULTRON_CUSTOM_BASE_URL=
ULTRON_CUSTOM_API_KEY=
ULTRON_CUSTOM_MODEL=
NOTION_ACCESS_TOKEN=

# Provider defaults
OPENAI_MODEL=gpt-5.6
ANTHROPIC_MODEL=claude-opus-4-8
